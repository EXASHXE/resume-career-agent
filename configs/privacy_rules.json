{
  "skip_dirs": [".git", "__pycache__", ".pytest_cache", "dist", "build", "node_modules", ".mypy_cache", ".tox", ".venv", "venv"],
  "forbidden_paths": [
    "resources/profiles/default/",
    "resources/profiles/default/projects/",
    ".private/",
    ".local/",
    "private/",
    "local/",
    "personal/",
    "resume/",
    "resumes/",
    "jd/",
    "jds/",
    "materials/",
    "career-assets/"
  ],
  "generic_patterns": [
    ["(?i)(?:private[_-]?key|secret[_-]?key|api[_-]?key|access[_-]?token)\\s*[:=]\\s*\\S{8,}", "secret/key/token pattern"],
    ["(?i)password\\s*[:=]\\s*\\S{4,}", "password assignment"],
    ["-----BEGIN (?:\\w+ )?PRIVATE KEY-----", "PEM private key"],
    ["(?<!\\d)(?:86)?1[3-9]\\d{9}(?!\\d)", "phone number pattern"],
    ["\\b\\d{17}[\\dXx]\\b", "ID number pattern"],
    ["\\b\\d{6}\\s*\\d{4}\\s*\\d{2}\\s*\\d{2}\\s*[\\dXx]\\b", "ID number pattern"]
  ],
  "exempt_path": "resources/profiles/example/projects/",
  "denylist_example": ".privacy-denylist.example",
  "denylist_local": ".privacy-denylist.local"
}
